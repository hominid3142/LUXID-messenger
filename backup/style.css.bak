:root {
  --blue: #007aff;
  --bg: #ffffff;
  --sidebar-bg: #f8f8f9;
  --gray-bubble: #f2f2f7;
  --text-main: #1c1c1e;
  --text-sub: #8e8e93;
  --border: #e5e5ea;
  --accent-green: #32d74b;
  --accent-pink: #ff2d55;
  --nav-height: 60px;
  --app-max-width: 450px; /* 모바일 기준 폭 설정 */
}
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      sans-serif;
}
body {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #1c1c1e; /* 외부 배경색 */
  /* 좌우 배경 이미지 설정 */
  background-image: url("https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&q=80&w=2564");
  background-size: cover;
  background-position: center;
  color: var(--text-main);
  overflow: hidden;
}
/* [통합 앱 컨테이너] */
#app-wrapper {
  width: 100%;
  max-width: var(--app-max-width);
  height: 100%;
  background: var(--bg);
  box-shadow: 0 0 40px rgba(0, 0, 0, 0.5); /* 속성명 누락 수정 */
  display: flex;
  flex-direction: column;
  position: relative; /* 자식 요소의 absolute 기준점 설정을 위해 추가 */
}
/* [레이아웃 컨테이너 - 모바일 구조로 통일] */
#sidebar,
#main-chat,
#dev-panel {
  width: 100%;
  position: absolute;
  height: calc(100% - var(--nav-height));
  top: 0;
  left: 0;
  background: #fff;
}
#sidebar {
  display: flex;
  flex-direction: column;
  background: var(--sidebar-bg);
  z-index: 10;
}
#main-chat {
  display: none;
  flex-direction: column;
  z-index: 20;
}
#dev-panel {
  padding: 25px;
  display: none;
  flex-direction: column;
  gap: 6px;
  overflow-y: auto;
  z-index: 30;
}
/* [상태 관리용 클래스 - 단일 로직] */
body.is-chatting #main-chat {
  display: flex;
}
body.is-dev #dev-panel {
  display: flex;
}
body.show-auth #dev-auth-overlay {
  display: flex;
}
/* [네비게이션 및 백버튼 - 항상 유지] */
.bottom-nav {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: var(--nav-height);
  background: #fff;
  border-top: 1px solid var(--border);
  display: flex;
  z-index: 100;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: var(--text-sub);
  cursor: pointer;
}
.nav-item.active {
  color: var(--blue);
  font-weight: bold;
}
/* 개발자 탭 숨김 처리 */
.nav-item#nav-dev {
  display: none;
}
body.dev-unlocked .nav-item#nav-dev {
  display: flex;
}
.mobile-back {
  font-size: 24px;
  color: var(--blue);
  cursor: pointer;
  padding-right: 15px;
}
.dev-trigger-btn {
  padding: 2px 6px;
  font-size: 10px;
  font-weight: 800;
  color: var(--text-sub);
  border: 1px solid var(--border);
  background: none;
  border-radius: 4px;
  cursor: pointer;
  opacity: 0.6;
}
/* [1. 친구 목록 UI] */
.side-header {
  padding: 20px 25px;
  border-bottom: 1px solid var(--border);
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.side-header h1 {
  color: var(--text-main);
  font-size: 22px;
  font-weight: 800;
}
.server-status-wrap {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-left: 10px;
  font-size: 10px;
  font-weight: 700;
  color: var(--text-sub);
}
#friend-list,
#chat-list {
  flex: 1;
  overflow-y: auto;
  padding: 5px 0;
}
#chat-list {
  display: none;
}
.friend-item {
  padding: 12px 20px;
  cursor: pointer;
  transition: 0.2s;
  display: flex;
  align-items: center;
  gap: 15px;
  position: relative;
}
.friend-item:hover {
  background: rgba(0, 0, 0, 0.03);
}
.friend-avatar {
  width: 50px;
  height: 50px;
  background: #ddd;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  color: #fff;
  font-size: 18px;
  position: relative;
}
/* 친구 탭 온라인 상태 점 */
.online-dot {
  position: absolute;
  bottom: -2px;
  right: -2px;
  width: 14px;
  height: 14px;
  background: var(--accent-green);
  border: 3px solid #fff;
  border-radius: 50%;
  display: none;
}
.is-online .online-dot {
  display: block;
}

.friend-info {
  flex: 1;
  min-width: 0;
}
.friend-info .name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2px;
}
.friend-info .name {
  font-weight: 700;
  font-size: 15px;
  color: var(--text-main);
}
.friend-info .mbti {
  font-size: 10px;
  color: var(--blue);
  font-weight: 600;
  background: rgba(0, 122, 255, 0.1);
  padding: 1px 4px;
  border-radius: 4px;
}
.friend-info .last-msg {
  font-size: 13px;
  color: var(--text-sub);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  opacity: 0.8;
}
/* 안 읽은 메시지 배지 */
.unread-badge {
  background: var(--accent-pink);
  color: #fff;
  font-size: 10px;
  font-weight: bold;
  padding: 2px 6px;
  border-radius: 10px;
  min-width: 18px;
  text-align: center;
  display: none;
}
.has-unread .unread-badge {
  display: block;
}

.delete-btn {
  position: absolute;
  right: 10px;
  top: 15px;
  background: none;
  border: none;
  color: #ccc;
  font-size: 18px;
  cursor: pointer;
  display: none;
}
.friend-item:hover .delete-btn {
  display: block;
}
.add-btn {
  margin: 15px;
  padding: 12px;
  background: var(--gray-bubble);
  color: var(--text-main);
  border: none;
  border-radius: 12px;
  font-weight: 700;
  cursor: pointer;
  font-size: 13px;
}
/* 앱 내 상단 알림 팝업 */
#noti-popup {
  position: absolute;
  top: -80px;
  left: 10px;
  right: 10px;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 12px 15px;
  border-radius: 15px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: top 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  cursor: pointer;
}
#noti-popup.show {
  top: 10px;
}
#noti-popup img {
  width: 40px;
  height: 40px;
  border-radius: 14px;
}
#noti-popup .noti-content {
  flex: 1;
  min-width: 0;
}
#noti-popup .noti-name {
  font-weight: 800;
  font-size: 13px;
}
#noti-popup .noti-text {
  font-size: 12px;
  color: var(--text-sub);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* [2. 대화창 UI] */
#chat-header {
  height: 60px;
  padding: 0 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
}
.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.header-info .name {
  font-weight: 700;
  font-size: 16px;
}
.header-info .status {
  font-size: 11px;
  color: var(--text-sub);
  font-weight: 400;
  margin-top: 1px;
  height: 14px;
  transition: color 0.3s;
}
.header-info .status.online {
  color: var(--accent-green);
}
.header-info .status.offline {
  color: var(--text-sub);
}
.header-info .status.typing {
  color: var(--blue);
  font-weight: bold;
}
#chat-area {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: #fff;
}
.bubble {
  padding: 10px 14px;
  border-radius: 18px;
  font-size: 14.5px;
  max-width: 75%;
  line-height: 1.4;
  position: relative;
}
.bubble.user {
  background: var(--blue);
  color: #fff;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
}
.bubble.ai {
  background: var(--gray-bubble);
  color: var(--text-main);
  align-self: flex-start;
  border-bottom-left-radius: 4px;
}
.msg-meta {
  font-size: 10px;
  color: var(--text-sub);
  margin: 2px 5px;
}
.msg-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 4px;
}
.msg-row.user {
  align-items: flex-end;
}
.msg-row.ai {
  align-items: flex-start;
}
#input-area {
  padding: 15px 20px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 10px;
  background: #fff;
}
#msg-input {
  flex: 1;
  padding: 10px 18px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--gray-bubble);
  outline: none;
  font-size: 15px;
}
#send-btn {
  width: 40px;
  height: 40px;
  background: var(--blue);
  border: none;
  border-radius: 50%;
  color: #fff;
  cursor: pointer;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* [3. 개발자 패널 & 보안 UI] */
.panel-title {
  font-size: 11px;
  font-weight: 900;
  color: #c7c7cc;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  margin-bottom: 4px;
  margin-top: 10px;
  flex-shrink: 0;
}
#persona-info {
  background: var(--gray-bubble);
  padding: 15px;
  border-radius: 12px;
  font-size: 13px;
  line-height: 1.6;
  flex-shrink: 0;
}
.param-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  background: var(--gray-bubble);
  padding: 15px;
  border-radius: 12px;
  flex-shrink: 0;
}
.grid-col-title {
  font-size: 10px;
  font-weight: 800;
  color: var(--text-sub);
  margin-bottom: 8px;
  text-align: center;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  padding-bottom: 4px;
}
.param-item {
  margin-bottom: 8px;
}
.param-item label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  margin-bottom: 3px;
}
.param-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 2px 6px;
}
.param-input-wrap input {
  width: 100%;
  border: none;
  outline: none;
  font-size: 12px;
  font-weight: 800;
  text-align: right;
}
.param-input-wrap span {
  font-size: 10px;
  color: var(--text-sub);
  margin-left: 2px;
}
#plan-info {
  background: var(--gray-bubble);
  padding: 15px;
  border-radius: 12px;
  font-size: 12px;
  line-height: 1.6;
  color: var(--text-main);
  flex-shrink: 0;
}
#plan-info b {
  color: var(--blue);
  font-size: 10px;
  text-transform: uppercase;
}
.dev-log-window {
  background: #1c1c1e;
  color: var(--accent-green);
  padding: 12px;
  border-radius: 10px;
  font-family: monospace;
  font-size: 11px;
  line-height: 1.5;
  height: 100px;
  min-height: 100px;
  flex-shrink: 0;
  overflow-y: auto;
  border: 1px solid #2d2d30;
  white-space: pre-line;
}
.dev-log-window::-webkit-scrollbar {
  width: 3px;
}
.dev-log-window::-webkit-scrollbar-thumb {
  background: #444;
}
.engine-ctrl {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: var(--gray-bubble);
  padding: 12px;
  border-radius: 12px;
  flex-shrink: 0;
}
.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ff453a;
}
.status-dot.active {
  background: var(--accent-green);
  box-shadow: 0 0 8px var(--accent-green);
}
.shutdown-btn {
  background: #ff453a;
  color: white;
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 800;
  cursor: pointer;
}
#dev-auth-overlay {
  position: absolute;
  inset: 0;
  background: #fff;
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  text-align: center;
  display: none; /* 기본 숨김 */
}
#dev-auth-overlay h2 {
  font-size: 18px;
  margin-bottom: 20px;
}
#pass-input {
  width: 100%;
  max-width: 200px;
  padding: 12px;
  border: 1px solid var(--border);
  border-radius: 10px;
  text-align: center;
  font-size: 20px;
  letter-spacing: 4px;
  outline: none;
  margin-bottom: 15px;
}
.auth-btn {
  width: 100%;
  max-width: 200px;
  padding: 12px;
  background: var(--text-main);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-weight: bold;
  cursor: pointer;
}
::-webkit-scrollbar {
  width: 4px;
}
::-webkit-scrollbar-thumb {
  background: #d1d1d6;
  border-radius: 10px;
}