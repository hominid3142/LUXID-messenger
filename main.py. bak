@app.delete("/delete-friend/{room_id}")
def delete_friend(room_id: int):
    db = SessionLocal()
    room = db.query(ChatRoom).filter(ChatRoom.id == room_id).first()
    if room:
        db.delete(room.persona)
        db.commit()
        db.close()
    return {"status": "deleted"}


