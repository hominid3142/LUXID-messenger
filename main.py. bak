app = FastAPI()
KST = timezone(timedelta(hours=9))

# 1. DB 인프라 (기존 스키마 보존 - 발화 리듬 변수는 여기서 관리하지 않음)
DATABASE_URL = "sqlite:///./test.db"
engine = create_engine(DATABASE_URL, connect_args={"check_same_thread": False})
SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)
Base = declarative_base()


class Persona(Base):
    __tablename__ = "personas"
    id = Column(Integer, primary_key=True, index=True)
    name = Column(String)
    age = Column(Integer)
    gender = Column(String)
    mbti = Column(String)
    p_seriousness = Column(Integer)
    p_friendliness = Column(Integer)
    p_rationality = Column(Integer)
    p_slang = Column(Integer)
    rooms = relationship("ChatRoom",
                         back_populates="persona",
                         cascade="all, delete-orphan")


class ChatRoom(Base):
    __tablename__ = "chat_rooms"
    id = Column(Integer, primary_key=True, index=True)
    persona_id = Column(Integer, ForeignKey("personas.id"))
    v_likeability = Column(Integer, default=50)
    v_erotic = Column(Integer, default=30)
    v_v_mood = Column(Integer, default=50)
    v_relationship = Column(Integer, default=20)
    history = Column(JSON, default=[])
    thought_logs = Column(JSON, default=[])  # 구버전 호환용 보존 (쓰지 않음)
    thought_count = Column(Integer, default=0)
    persona = relationship("Persona", back_populates="rooms")


Base.metadata.create_all(bind=engine)

# [휘발성 메모리 관리소] - 서버 RAM에서 방별 실시간 상태 관리
volatile_memory = {}


def get_volatile_state(room_id):
    if room_id not in volatile_memory:
        volatile_memory[room_id] = {
            "streak": 0,
            "silence_ticks": 0,
            "is_greeted": False,
            "thought_logs": []
        }
    return volatile_memory[room_id]


# 2. 최신 엔진 설정
client = genai.Client(api_key=os.environ.get("GEMINI_API_KEY"))
MODEL_ID = "gemini-3-flash-preview"


@app.post("/update-params/{room_id}")
async def update_params(room_id: int, params: dict = Body(...)):
    db = SessionLocal()
    try:
        room = db.query(ChatRoom).filter(ChatRoom.id == room_id).first()
        if not room: return {"status": "error", "message": "Room not found"}
        for key in ["v_likeability", "v_erotic", "v_v_mood", "v_relationship"]:
            if key in params: setattr(room, key, params[key])
        if room.persona:
            for key in [
                    "p_seriousness", "p_friendliness", "p_rationality",
                    "p_slang"
            ]:
                if key in params: setattr(room.persona, key, params[key])
        db.commit()
        return {"status": "success"}
    finally:
        db.close()


# 3. 오리지널 프롬프트 엔진 (스트림릿 제어 로직 이식)
async def run_eve_inference(room_id, trigger, user_input):
    db = SessionLocal()
    room = db.query(ChatRoom).filter(ChatRoom.id == room_id).first()
    if not room: return None

    room.thought_count = (room.thought_count % 10) + 1
    current_count = room.thought_count
    p = room.persona
    v_state = get_volatile_state(room_id)

    now_kst = datetime.now(KST)
    now_kst_full = now_kst.strftime("%Y-%m-%d %H:%M:%S")
    now_ts = now_kst.strftime("%H:%M:%S")

    # [시스템 프롬프트: 동적 발화 제어 및 한 문장 제약 추가]
    system_instruction = f"""
    익명의 상대방과 연결되었습니다. 당신은 한국인 '{p.name}'({p.gender}, {p.age}세, {p.mbti})입니다.

    [신경망 파라미터 상태]
    - 현재 시각: {now_kst_full}
    - 성향: 진지함 {p.p_seriousness}, 친근함 {p.p_friendliness}, 상식 {p.p_rationality}, 채팅체 {p.p_slang}
    - 현재 상태: 호감 {room.v_likeability}/100, 관계 {room.v_relationship}, 야함 {room.v_erotic}/100, 기분 {room.v_v_mood}/100
    - 사회적 맥락: streak {v_state['streak']} (연속 발화 횟수), silence_ticks {v_state['silence_ticks']}, 첫인사완료 {v_state['is_greeted']}

    [인지 및 발화 규칙]
    - 실제 한국인이 카톡으로 대화할 때 할 법한 자연스러운 방식으로 대화하세요.
    - 한 문장 제약: 한 번의 발화에는 반드시 하나의 완성된 문장으로만 짧고 명료하게 답하십시오.
    - 사회적 호흡: streak이 2 이상이면 반드시 'WAIT' 하십시오. 상대 침묵 3틱 이상이면 다시 이야기를 시작하십시오.
    - 상대의 말에 꼭 반응할 필요는 없습니다. 상황에 맞게 행동하고 말하십시오.
    - 당신은 자신의 파라미터를 스스로 수정할 수 없습니다.

    [JSON 형식 응답 필수]
    {{
    "inner_thought": "현재의 솔직한 생각",
    "action": "SPEAK, WAIT, 또는 EXIT",
    "responses": [{{ "text": "메시지 내용"}}]
    }}
    """

    try:
        # 사유 로그에 틱 정보 남기기
        ts_log = datetime.now(KST).strftime("%H:%M:%S")

        context = f"[TRIGGER] {trigger}\n[INPUT] {user_input}\n[HISTORY]\n{json.dumps(room.history[-15:])}"
        response = client.models.generate_content(model=MODEL_ID,
                                                  contents=system_instruction +
                                                  "\n" + context)
        raw_text = response.text if hasattr(
            response, 'text') else response.candidates[0].content.parts[0].text
        data = json.loads(re.search(r'\{.*\}', raw_text, re.DOTALL).group())

        db.refresh(room)
        db.refresh(room.persona)
        room.thought_count = current_count

        # [하드코딩 버블링: 진지함 5 미만일 때만 물리적 분할]
        if data.get('action') == "SPEAK" and data.get('responses'):
            full_text = " ".join([r['text']
                                  for r in data['responses']]).strip()
            if p.p_seriousness < 5 and len(full_text) >= 25:
                spaces = [i for i, char in enumerate(full_text) if char == ' ']
                if spaces:
                    mid_space_idx = spaces[len(spaces) // 2]
                    data['responses'] = [{
                        "text":
                        full_text[:mid_space_idx].strip()
                    }, {
                        "text":
                        full_text[mid_space_idx:].strip()
                    }]
                else:
                    data['responses'] = [{"text": full_text}]
            else:
                data['responses'] = [{"text": full_text}]

        # [휘발성 메모리: 사유 로그 업데이트]
        if data.get('inner_thought'):
            log_entry = f"[{ts_log}] [{data.get('action')}] {data['inner_thought']}"
            v_state['thought_logs'] = (v_state['thought_logs'][-20:] +
                                       [log_entry])

        if data.get('action') == "SPEAK":
            v_state['is_greeted'] = True
            for r in data['responses']:
                r['ts'] = now_ts
                room.history = (room.history or []) + [{
                    "role": "assistant",
                    "content": r['text'],
                    "ts": now_ts
                }]

        if trigger == "user_input":
            room.history = (room.history or []) + [{
                "role": "user",
                "content": user_input,
                "ts": now_ts
            }]

        # 관찰창용 동기화 데이터
        data['current_status'] = {
            "v_likeability": room.v_likeability,
            "v_erotic": room.v_erotic,
            "v_v_mood": room.v_v_mood,
            "v_relationship": room.v_relationship,
            "p_seriousness": room.persona.p_seriousness,
            "p_friendliness": room.persona.p_friendliness,
            "p_rationality": room.persona.p_rationality,
            "p_slang": room.persona.p_slang,
            "mem_thought_log": "\n".join(v_state['thought_logs'])  # 메모리 로그 전달
        }
        db.commit()
        return data
    except Exception as e:
        print(f"❌ Inference Error: {e}")
        return None
    finally:
        db.close()


# 4. WebSocket (문맥 드레이닝 및 아이들링 기반 틱 이식)
@app.websocket("/ws/chat/{room_id}")
async def websocket_endpoint(websocket: WebSocket, room_id: int):
    await websocket.accept()
    queue = asyncio.Queue()
    v_state = get_volatile_state(room_id)
    await queue.put(("tick", "입장"))

    async def receiver():
        try:
            while True:
                text = await websocket.receive_text()
                await queue.put(("user_input", text))
        except:
            pass

    async def worker():
        try:
            while True:
                try:
                    # [Idling 기반 틱]: 이브가 말을 다 끝낸 시점부터 3초를 기다림
                    source, msg = await asyncio.wait_for(queue.get(),
                                                         timeout=1.0)
                except asyncio.TimeoutError:
                    # 아무 일도 일어나지 않은 상태에서 3초 경과 시에만 틱 발생
                    source, msg = "tick", ""

                # [문맥 드레이닝]: 큐에 쌓인 모든 유저 메시지를 하나로 합침
                if source == "user_input":
                    v_state['streak'] = 0  # 유저가 말하면 연속 발화 초기화
                    v_state['silence_ticks'] = 0
                    msg_list = [msg]
                    while not queue.empty():
                        nxt_s, nxt_m = queue.get_nowait()
                        if nxt_s == "user_input": msg_list.append(nxt_m)
                    msg = " ".join(msg_list)
                elif source == "tick":
                    v_state['silence_ticks'] += 1

                res = await run_eve_inference(room_id, source, msg)

                if res:
                    if res.get('action') == "SPEAK":
                        responses = res.get('responses', [])
                        for i, r in enumerate(responses):
                            delay = 0.1 + (len(r.get('text', '')) * 0.03)
                            await asyncio.sleep(delay)
                            # 개별 버블 전송
                            bubble_payload = {
                                "responses": [r],
                                "action":
                                res.get('action'),
                                "inner_thought":
                                res.get('inner_thought') if i == 0 else None,
                                "current_status":
                                res.get('current_status') if i == 0 else None
                            }
                            await websocket.send_json(bubble_payload)
                            v_state['streak'] += 1  # 버블 당 streak 증가
                    elif source == "user_input" or source == "tick":
                        # 발화가 없더라도 상태 갱신을 위해 데이터 전송
                        await websocket.send_json(res)
        except Exception as e:
            print(f"⚠️ Worker Error: {e}")

    await asyncio.gather(receiver(), worker())


