
/* [v3.5.0] Chat View Toggle */
#main-chat {
  display: none;
  flex-direction: column;
  height: 100%;
  width: 100%;
  background: var(--bg);
  position: absolute;
  top: 0;
  left: 0;
  z-index: 100;
}

body.is-chatting #main-chat {
  display: flex !important;
}

body.is-chatting #sidebar,
body.is-chatting .bottom-nav {
  display: none !important;
}
