modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "python main.py --reload"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["psmisc"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[env]

[deployment]
build = [
  "pip",
  "install",
  "fastapi",
  "uvicorn",
  "sqlalchemy",
  "google-genai",
  "psycopg2-binary",
]
deploymentTarget = "autoscale" # 현재 무료 티어이므로 autoscale로 유지됨
run = ["python", "main.py"]
healthCheckPath = "/health" # 이 줄을 추가

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[userenv]

[userenv.shared]
